# Copy this file to server/.env and fill in your real values.
# The proxy substitutes ${VAR} references found in request URLs, headers, and
# bodies with the matching environment variable below — so secrets stay here
# and never get typed into (or stored by) the browser.

PORT=8787

# API key and website key are NOT stored here — they vary case-by-case and are
# entered by the user in the tool when making a request.

# Default base URLs per API (override per-request in the UI if needed).
# Source: https://developer.helloretail.com/api/ — all are HTTP POST with a
# JSON body and Content-Type application/json.
HR_RECOMMENDATIONS_BASE=https://core.helloretail.com/serve/recoms
HR_SEARCH_BASE=https://core.helloretail.com/serve/search
# Pages requests target /serve/pages/{key}; append the page key in the UI.
HR_PAGES_BASE=https://core.helloretail.com/serve/pages
